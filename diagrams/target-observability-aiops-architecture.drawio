        <mxCell id="leg-text-6" value="&lt;b&gt;Traces&lt;/b&gt;&lt;br&gt;Tempo stores 14d traces and service graph data for RCA." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="555" width="510" height="70" as="geometry"/></mxCell>
