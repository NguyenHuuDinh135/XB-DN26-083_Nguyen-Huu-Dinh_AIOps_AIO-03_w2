        <mxCell id="leg-text-3" value="&lt;b&gt;Metrics&lt;/b&gt;&lt;br&gt;VictoriaMetrics keeps 30d hot PromQL data for dashboards and alert rules." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="255" width="510" height="70" as="geometry"/></mxCell>
        <mxCell id="leg-4" value="4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#0b4f71;fontColor=#FFFFFF;fontStyle=1;fontSize=20;fontFamily=Helvetica;shadow=1;strokeWidth=2;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1712" y="355" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-text-4" value="&lt;b&gt;Logs&lt;/b&gt;&lt;br&gt;Loki keeps 7d hot operational logs; ClickHouse keeps analytical/audit SQL path." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="355" width="510" height="70" as="geometry"/></mxCell>
