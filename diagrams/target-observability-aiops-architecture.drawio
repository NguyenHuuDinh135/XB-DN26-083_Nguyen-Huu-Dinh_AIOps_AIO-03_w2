        <mxCell id="leg-text-1" value="&lt;b&gt;OTLP ingestion&lt;/b&gt;&lt;br&gt;10 services export metrics, logs and traces through one OpenTelemetry pipeline." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="55" width="510" height="70" as="geometry"/></mxCell>
        <mxCell id="leg-2" value="2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#0b4f71;fontColor=#FFFFFF;fontStyle=1;fontSize=20;fontFamily=Helvetica;shadow=1;strokeWidth=2;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1712" y="155" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-text-2" value="&lt;b&gt;Governance&lt;/b&gt;&lt;br&gt;Policy processor handles sampling, PII redaction and cardinality limits before storage." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="155" width="510" height="70" as="geometry"/></mxCell>
