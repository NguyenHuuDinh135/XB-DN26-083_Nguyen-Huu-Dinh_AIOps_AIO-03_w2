        <mxCell id="leg-text-5" value="&lt;b&gt;Cold retention&lt;/b&gt;&lt;br&gt;S3 stores cold logs for 1 year via lifecycle policy and Athena/S3 Select access." style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=0;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1765" y="455" width="510" height="70" as="geometry"/></mxCell>
